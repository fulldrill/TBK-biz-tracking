# ============================================================
# BizTrack Backend – Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# Security: generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string-in-production

# Database connection string (used automatically by docker-compose)
DATABASE_URL=postgresql://biztrack:biztrack_secret@localhost:5432/biztrack

# Plaid API credentials
# Get them free at: https://dashboard.plaid.com
#   1. Create an account at dashboard.plaid.com
#   2. Go to Team Settings > Keys
#   3. Copy Client ID and Sandbox Secret below
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_sandbox_secret_here
PLAID_ENV=sandbox

# Comma-separated list of frontend origins allowed by CORS.
# Add your production domain here when deploying.
# Default: http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

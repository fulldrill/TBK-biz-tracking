# ============================================================
# BizTrack Receipts - Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Security - generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string-in-production

# Database (used by docker-compose automatically)
DATABASE_URL=postgresql://biztrack:biztrack_secret@localhost:5444/biztrack

# Plaid API Keys
# Get these FREE from: https://dashboard.plaid.com
# 1. Create account at dashboard.plaid.com
# 2. Go to Team Settings > Keys
# 3. Copy Client ID and Sandbox Secret below
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_sandbox_secret_here
PLAID_ENV=sandbox

# OpenAI — required for Statement Parser (PDF upload → AI extraction)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================
# BizTrack Frontend – Local Environment Variables
# Copy this file to .env.local and fill in your values.
# Next.js only exposes variables prefixed with NEXT_PUBLIC_ to the browser.
# ============================================================

# URL of the running backend API.
# Change this if your backend runs on a different host or port.
# Default (matches the Docker Compose setup): http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
